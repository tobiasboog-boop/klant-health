# ============================================================
#  klant-health — environment variabelen
# ============================================================
# Kopieer naar .env (NOOIT committen). Op VPS4 staat .env in
# /opt/notifica/apps/drafts/klant-health/.env (EnvironmentFile van de service).

# --- Pipedrive (klant-contacten + lead-verrijking) ---
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=

# --- EmailOctopus (lead engagement: opens/clicks) ---
EMAILOCTOPUS_API_KEY=

# --- Power BI Admin API (klant-health: report-views per organisatie) ---
# Azure AD service principal (lid van pbisecurity-groep)
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=

# --- PostgreSQL opslag op VPS3 (PBI-cache, klantreis, bellijst, funnel-config) ---
# ALLEEN STREAMLIT_DB_PASSWORD is verplicht; host/poort/naam/user/schema hebben
# code-defaults (zie db.py) en hoef je dus niet in te vullen.
STREAMLIT_DB_PASSWORD=
STREAMLIT_DB_HOST=
STREAMLIT_DB_PORT=
STREAMLIT_DB_NAME=
STREAMLIT_DB_USER=
STREAMLIT_DB_SCHEMA=

# --- IPinfo.io (B2B website-bezoeker identificatie) ---
IPINFO_TOKEN=

# --- Microsoft Graph (mail-historie koppeling, optioneel) ---
MAIL_TENANT_ID=
MAIL_CLIENT_ID=
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Cloudflare Worker visitor-tracking API (website-bezoeken) ---
VISITOR_ADMIN_KEY=

# --- Anthropic (optioneel: AI-classificatie van mailreacties via Claude Haiku) ---
# Leeg laten = feature uit (valt terug op "Neutraal", geen crash).
ANTHROPIC_API_KEY=
